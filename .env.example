# Skopíruj tento súbor ako ".env" a doplň skutočné hodnoty.
# Súbor ".env" sa NIKDY necommituje (je v .gitignore).

FLASK_SECRET_KEY=zmen-ma-na-nahodny-dlhy-retazec

# E-mailový účet použitý na odosielanie notifikácií a resetu hesla.
# Pre Gmail použi "App Password", nie bežné heslo k účtu:
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=tvoj-email@gmail.com
MAIL_PASSWORD=tvoje-app-heslo

DATABASE_URL=sqlite:///sqlite.db
